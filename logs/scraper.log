  "reason": "alasan singkat keputusan kamu",
  "nextAnalyzeIn": "10m" | "15m" | "20m" | "30m" | "45m" | "1h",
  "contextSummary": "ringkasan 1-2 kalimat konteks percakapan"
}"")
